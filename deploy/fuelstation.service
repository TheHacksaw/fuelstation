[Unit]
Description=Fuel Station Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/fuelstation/proxy
EnvironmentFile=/etc/fuelstation.env
ExecStart=/opt/fuelstation/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
